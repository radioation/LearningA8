10 PMBASE=54279:SIZEM=53260
20 GUNH=564
30 GUNV=565
40 RAMTOP=106:HPOSM0=53252
50 SDMCTL=559:REM SHADOW DMACTL
60 GRACTL=53277
70 HPOSP0=53248:REM HORIZONTAL POSITION OF PO
80 HPOSP1=53249
90 HPOSP2=53250
100 HPOSP3=53251
110 PCOLR0=704:REM SHADOW OF PLAYER 0 COLOR
120 PCOLR1=705
130 PCOLR2=706
140 PCOLR3=707
150 GRAPHICS 0:SETCOLOR 2,9,8:SETCOLOR 1,0,14
160 X0=213:REM BASIC'S PLAYER HORIZONTAL POSITION
170 Y0=20:REM BASIC'S PLAYER VERTICAL POSITION
180 X1=25
190 Y1=40
200 X2=213
210 Y2=60
220 A=PEEK(RAMTOP)-8:REM GET RAM 2K BELOW TOP OF RAM
230 POKE PMBASE,A:REM TELL ANTIC WHERE PM RAM IS
240 MYPMBASE=256*A:REM KEEP TRACK OF PM RAM ADDRESS
250 POKE SDMCTL,46:REM PM DMA 2-LINE
260 POKE GRACTL,3:POKE SIZEM,3
270 REM OFFSCREEN
280 POKE HPOSP0,0
290 POKE HPOSP1,0
300 POKE HPOSP2,0
310 POKE HPOSP3,0
320 REM RECOLOR
330 POKE PCOLR0,15
340 POKE PCOLR1,30
350 POKE PCOLR2,120
360 POKE PCOLR3,125
370 FOR I=MYPMBASE+384 TO MYPMBASE+1024:REM THIS LOOP CLEARS PLAYER MEMORY
380 POKE I,0
390 NEXT I
400 REM PLAYER 0
410 DATA 12,28,24,57,255,57,24,28,12
420 DATA 48,56,24,156,255,156,24,56,48
430 RESTORE 410
440 FOR I=MYPMBASE+512+Y0 TO MYPMBASE+520+Y0
450 READ A:REM THIS LOOP DRAWS THE PLAYER
460 POKE I,A
470 NEXT I
480 RESTORE 420
490 FOR I=MYPMBASE+640+Y1 TO MYPMBASE+648+Y1
500 READ A:REM THIS LOOP DRAWS THE PLAYER
510 POKE I,A
520 NEXT I
530 RESTORE 410
540 FOR I=MYPMBASE+768+Y2 TO MYPMBASE+776+Y2
550 READ A:REM THIS LOOP DRAWS THE PLAYER
560 POKE I,A
570 NEXT I
571 OLDY=10
572 P0=1
573 P1=1
574 P2=1
580 POKE HPOSP0,X0
590 POKE HPOSP1,X1
600 POKE HPOSP2,X2
610 IF P0=1 THEN X0=X0-1:IF X0<25 THEN X0=213
620 IF P1=1 THEN X1=X1+1:IF X1>213 THEN X1=25
630 IF P2=1 THEN X2=X2-1:IF X2<25 THEN X2=213
640 GX=PEEK(GUNH)
650 GY=PEEK(GUNV)
660 POSITION 2,5
700 IF GY<>OLDY THEN POKE MYPMBASE+896+OLDY,0:POKE MYPMBASE+897+OLDY,0
710 POKE MYPMBASE+896+GY,192
720 POKE MYPMBASE+897+GY,192
730 OLDY=GY
740 CX=GX-40:REM -40 MAY CHANGE ON DIFFERENT SYSTEMS
750 IF CX<1 THEN CX=CX+227
760 POKE HPOSP3,CX
770 IF STICK(0)=15 THEN GOTO 1000
900 GOTO 580
1000 IF CX>X0 AND CX<X0+8 AND GY>Y0 AND GY<Y0+9 THEN P0=0:X0=1
1010 IF CX>X1 AND CX<X1+8 AND GY>Y1 AND GY<Y1+9 THEN P1=0:X1=1
1020 IF CX>X2 AND CX<X2+8 AND GY>Y2 AND GY<Y2+9 THEN P2=0:X2=1
1050 GOTO 580
1060 PRINT "CX: ";CX
1065 PRINT "CY: ";CY
1070 PRINT "X0: ";X0
1075 PRINT "Y0: ";Y0
1080 PRINT "P0: ";P0

