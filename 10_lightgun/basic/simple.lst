10 PMBASE=54279:SIZEM=53260
20 GUNH=564
30 GUNV=565
40 RAMTOP=106:HPOSM0=53252
50 SDMCTL=559:REM SHADOW DMACTL
60 GRACTL=53277
70 HPOSP0=53248:REM HORIZONTAL POSITION OF PO
80 PCOLR0=704:REM SHADOW OF PLAYER 0 COLOR
90 GRAPHICS 0:SETCOLOR 2,9,8:SETCOLOR1,0,14
100 A=PEEK(RAMTOP)-8:REM GET RAM 2K BELOW TOP OF RAM
110 POKE PMBASE,A:REM TELL ANTIC WHERE PM RAM IS
120 MYPMBASE=256*A:REM KEEP TRACK OF PM RAM ADDRESS
130 POKE SDMCTL,46:REM PM DMA 2-LINE
140 POKE GRACTL,3:POKE SIZEM,3
150 REM OFFSCREEN
160 POKE HPOSP0,0
170 REM RECOLOR
180 POKE PCOLR0,15
190 FOR I=MYPMBASE+384 TO MYPMBASE+1024:REM THIS LOOP CLEARS PLAYER MEMORY
200 POKE I,0
210 NEXT I
220 OLDY = 10
230 GX=PEEK(GUNH)
240 GY=PEEK(GUNV)
250 POSITION 2,5
260 IF GY<>OLDY THEN POKE MYPMBASE+512+OLDY,0:POKE MYPMBASE+513+OLDY,0
270 POKE MYPMBASE+512+GY,192
280 POKE MYPMBASE+513+GY,192
290 OLDY=GY
300 CX = GX -40 : REM -40 MAY CHANGE ON DIFFERENT SYSTEMS
310 IF CX < 1 THEN CX = CX + 227
320 POKE HPOSP0,CX
330 GOTO 230
